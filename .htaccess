Options +FollowSymLinks -MultiViews
RewriteEngine On

# Home page
RewriteRule ^$ router.php [L,QSA]

# Blog routes
RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog-details.php?slug=$1 [L,QSA]

# CMS page slugs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)/?$ router.php?slug=$1 [L,QSA]
